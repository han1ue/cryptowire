{
    "rewrites": [
        {
            "source": "/rss.xml",
            "destination": "https://api.cryptowi.re/rss.xml"
        },
        {
            "source": "/widget",
            "destination": "/widget/index.html"
        },
        {
            "source": "/widget/(.*)",
            "destination": "/widget/$1"
        },
        {
            "source": "/news",
            "destination": "https://api.cryptowi.re/news"
        },
        {
            "source": "/news/(.*)",
            "destination": "https://api.cryptowi.re/news/$1"
        },
        {
            "source": "/prices",
            "destination": "https://api.cryptowi.re/prices"
        },
        {
            "source": "/prices/(.*)",
            "destination": "https://api.cryptowi.re/prices/$1"
        },
        {
            "source": "/market",
            "destination": "https://api.cryptowi.re/market"
        },
        {
            "source": "/health",
            "destination": "https://api.cryptowi.re/health"
        },
        {
            "source": "/stats",
            "destination": "https://api.cryptowi.re/stats"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "outputDirectory": "dist"
}
