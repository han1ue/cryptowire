{
  "name": "cryptowire",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,api -c blue,green \"npm run dev -w @cryptowire/frontend\" \"npm run dev -w @cryptowire/api\"",
    "dev:frontend": "npm run dev -w @cryptowire/frontend",
    "dev:api": "npm run dev -w @cryptowire/api",
    "dev:docs": "npm run dev -w @cryptowire/docs",
    "docs:sync-sources": "node scripts/generate-sources-docs.mjs",
    "build:widget": "npm run build -w @cryptowire/widget",
    "check:widget-sync": "npm run build:widget && git diff --exit-code -- apps/frontend/public/widget/widget.js",
    "build": "npm --workspaces run build --if-present",
    "test:api": "npm run test -w @cryptowire/api",
    "test:adapters": "npm run test -w @cryptowire/adapters",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
